    "express": "^5.2.1",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "pokersolver": "^2.1.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
